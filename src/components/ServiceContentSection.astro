---
import { Image } from 'astro:assets';
import { ArrowRight, Check } from '@lucide/astro';

interface Props {
  section: any;
  index: number;
}

const { section, index } = Astro.props;
const isLight = index % 2 === 0;
const isCentered = section.layout === 'centered';
const isImageCards = section.layout === 'image-cards';
const isVideoGrid = section.layout === 'video-grid';
const hasVideos = Boolean(section.videos?.length);
const isPersonaPanels = section.itemLayout === 'persona-panels';
---

<section class:list={[
  'px-5 py-16 sm:px-6 sm:py-24 lg:px-8',
  isLight ? 'bg-acc-mist' : 'relative bg-[linear-gradient(135deg,#0b4850_0%,#073942_48%,#02293c_100%)] text-white',
]}>
  {!isLight && <div class="hero-noise absolute inset-0 opacity-70"></div>}
  <div class:list={[
    'relative mx-auto',
    isCentered && hasVideos ? 'max-w-6xl text-center' : isCentered ? 'max-w-3xl text-center' : isImageCards || isVideoGrid ? 'max-w-6xl text-center' : 'grid max-w-6xl gap-12 lg:grid-cols-[0.42fr_1fr]',
  ]}>
    <div class:list={[
      !isCentered && !isImageCards && !isVideoGrid && 'lg:sticky lg:top-32 lg:self-start',
    ]}>
      <p class:list={[
        'text-[0.68rem] font-black uppercase tracking-[0.3em]',
        isLight ? 'text-[#4f93a2]' : 'text-[#65b6ca]',
      ]}>{section.eyebrow}</p>
      <h2 class:list={[
        'mt-5 text-4xl font-black leading-[1.02] tracking-tight sm:text-5xl',
        isLight ? 'text-acc-ink' : 'text-white',
      ]}>{section.headline}</h2>
    </div>

    <div class:list={[
      'reveal-body',
      isCentered && (hasVideos ? 'mx-auto mt-9 max-w-6xl text-left' : 'mx-auto mt-9 max-w-3xl text-left'),
      (isImageCards || isVideoGrid) && 'mx-auto mt-10 max-w-6xl text-left',
    ]}>
      {section.body && (
        <div class:list={[
          'grid gap-5 text-base font-semibold leading-7',
          isLight ? 'text-[#164f59]/85' : 'text-white/75',
        ]}>
          {section.body.map((paragraph) => <p>{paragraph}</p>)}
        </div>
      )}

      {section.videos && !section.items && (
        <div class="mt-8 grid gap-6 lg:grid-cols-3">
          {section.videos.map((video) => (
            <article class="reveal-body overflow-hidden rounded-2xl border border-[#d5ded9] bg-white text-slate-700 shadow-sm transition hover:-translate-y-0.5 hover:border-[#9fcbd0] hover:shadow-xl hover:shadow-slate-950/7">
              <div class="aspect-video bg-black">
                <iframe
                  title={video.title}
                  src={video.src}
                  class="h-full w-full"
                  frameborder="0"
                  referrerpolicy="strict-origin-when-cross-origin"
                  allow="autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share"
                  allowfullscreen
                ></iframe>
              </div>
              <div class="p-6">
                <p class="text-[0.68rem] font-black uppercase tracking-[0.24em] text-[#62aebe]">Project Example</p>
                <h3 class="mt-4 text-xl font-black leading-tight text-acc-ink">{video.location}</h3>
                <p class="mt-4 text-sm font-semibold leading-6 text-slate-600">{video.copy}</p>
              </div>
            </article>
          ))}
        </div>
      )}

      {section.bullets && (
        <ul class:list={[
          'mt-8 grid gap-4',
          isCentered && hasVideos && 'mx-auto max-w-3xl',
        ]}>
          {section.bullets.map((bullet) => (
            <li class:list={[
              'flex gap-3 rounded-xl p-5 text-sm font-bold leading-6 shadow-sm',
              isLight ? 'border border-[#d5ded9] bg-white text-slate-700' : 'border border-white/12 bg-white/[0.04] text-white/76',
            ]}>
              <Check class="mt-1 h-4 w-4 shrink-0 text-[#62aebe]" />
              <span>{bullet}</span>
            </li>
          ))}
        </ul>
      )}

      {section.items && (
        <div class:list={[
          'mt-8 grid gap-5',
          isImageCards && 'lg:grid-cols-2',
        ]}>
          {section.items.map((item) => (
            isPersonaPanels ? (
              <article class="reveal-body flex gap-5 rounded-2xl border border-[#d5ded9] bg-white p-6 text-left shadow-sm transition hover:-translate-y-0.5 hover:border-[#9fcbd0] hover:shadow-xl hover:shadow-slate-950/7 sm:p-7">
                {item.image && (
                  <Image src={item.image.src} alt={item.image.alt} width={220} class="h-24 w-24 shrink-0 rounded-2xl object-cover sm:h-28 sm:w-28" />
                )}
                <div>
                  <h3 class="text-xl font-black leading-tight text-acc-ink">{item.title}</h3>
                  <p class="mt-3 text-sm font-semibold leading-6 text-slate-600">{item.copy}</p>
                </div>
              </article>
            ) : (
              <article class:list={[
                'reveal-body group relative overflow-hidden rounded-2xl shadow-sm transition hover:-translate-y-0.5',
                isImageCards ? '' : 'p-7',
                isLight
                  ? 'border border-[#d5ded9] bg-white hover:border-[#9fcbd0] hover:shadow-xl hover:shadow-slate-950/7'
                  : 'border border-white/12 bg-white/[0.035] hover:bg-white/[0.07]',
              ]}>
                {item.image && (
                  <Image src={item.image.src} alt={item.image.alt} width={900} class="h-56 w-full object-cover" />
                )}
                <div class:list={[
                  'relative',
                  isImageCards ? 'p-7' : '',
                ]}>
                  <h3 class:list={[
                    'text-xl font-black leading-tight',
                    isLight ? 'text-acc-ink' : 'text-white',
                  ]}>{item.title}</h3>
                  <p class:list={[
                    'mt-3 text-sm font-semibold leading-6',
                    isLight ? 'text-slate-600' : 'text-white/58',
                  ]}>{item.copy}</p>
                </div>
              </article>
            )
          ))}
        </div>
      )}

      {section.videos && section.items && (
        <div class:list={[
          'mt-8 grid gap-6',
          section.videoLayout === 'vertical-split' ? 'lg:grid-cols-1' : 'lg:grid-cols-2',
        ]}>
          {section.videos.map((video) => (
            <article class:list={[
              'reveal-body overflow-hidden rounded-2xl border border-[#d5ded9] bg-white text-slate-700 shadow-sm transition hover:-translate-y-0.5 hover:border-[#9fcbd0] hover:shadow-xl hover:shadow-slate-950/7',
              section.videoLayout === 'vertical-split' && 'grid md:grid-cols-[minmax(12rem,18rem)_1fr]',
            ]}>
              <div class:list={[
                'bg-black',
                section.videoLayout === 'vertical-split' ? 'aspect-[9/16] h-full w-full' : 'aspect-video',
              ]}>
                <iframe
                  title={video.title}
                  src={video.src}
                  class="h-full w-full"
                  frameborder="0"
                  referrerpolicy="strict-origin-when-cross-origin"
                  allow="autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share"
                  allowfullscreen
                ></iframe>
              </div>
              <div class="p-6">
                <h3 class="text-xl font-black leading-tight text-acc-ink">{video.location}</h3>
                <p class="mt-4 text-sm font-semibold leading-6 text-slate-600">{video.copy}</p>
              </div>
            </article>
          ))}
        </div>
      )}

      {section.steps && (
        <div class="mt-8 grid gap-5">
          {section.steps.map(([title, copy], stepIndex) => (
            <article class:list={[
              'reveal-body grid gap-5 rounded-2xl p-7 shadow-sm sm:grid-cols-[3.5rem_1fr]',
              isLight ? 'border border-[#d5ded9] bg-white' : 'border border-white/12 bg-white/[0.04]',
            ]}>
              <span class="flex h-12 w-12 items-center justify-center rounded-lg bg-[#e8f3f4] text-sm font-black text-[#0b4850] ring-1 ring-[#cfe3e7]">0{stepIndex + 1}</span>
              <div>
                <h3 class:list={[
                  'text-xl font-black leading-tight',
                  isLight ? 'text-acc-ink' : 'text-white',
                ]}>{title}</h3>
                <p class:list={[
                  'mt-3 text-sm font-semibold leading-6',
                  isLight ? 'text-slate-600' : 'text-white/58',
                ]}>{copy}</p>
              </div>
            </article>
          ))}
        </div>
      )}

      {section.cta && (
        <div class:list={[
          'reveal-body mt-9',
          isCentered ? 'text-center' : '',
        ]}>
          <a href={section.cta.href} class="btn-primary">
            {section.cta.label}
            <ArrowRight class="h-5 w-5" />
          </a>
        </div>
      )}

      {section.quote && (
        isCentered ? (
          <div class="mt-12 text-center">
            <span class:list={[
              'mx-auto block h-1 w-28 rounded-full bg-[linear-gradient(90deg,rgba(110,193,213,0),#6ec1d5_50%,rgba(110,193,213,0))]',
              !isLight && 'opacity-85',
            ]}></span>
            <blockquote class:list={[
              'mt-9 font-black text-2xl leading-9 sm:text-3xl sm:leading-10',
              isLight ? 'text-acc-ink' : 'text-white',
            ]}>
              {section.quote}
            </blockquote>
          </div>
        ) : (
          <blockquote class:list={[
            'mt-8 rounded-lg p-7 text-xl font-black leading-8 shadow-2xl',
            isLight ? 'bg-[#0b4850] text-white shadow-[#06333a]/25' : 'bg-white text-[#02293c] shadow-black/15',
          ]}>
            “{section.quote}”
          </blockquote>
        )
      )}
    </div>
  </div>
</section>
