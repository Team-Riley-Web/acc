---
import { Image } from 'astro:assets';
import { ArrowRight, ChevronDown, Clock3, Facebook, Heart, Instagram, Linkedin, MapPin, Menu, Phone, Share2, X, Youtube } from '@lucide/astro';
import logo from '../assets/images/logo.png';
import { servicesNav } from '../content/site';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="bg-[#063f46] font-sans text-acc-ink">
    <div class="min-h-screen overflow-x-clip">
      <header class="site-header fixed inset-x-0 top-0 z-50 px-5 py-6 sm:px-6 lg:px-8">
        <nav class="site-nav mx-auto grid w-full max-w-6xl grid-cols-[auto_1fr_auto] items-center gap-3 border border-transparent sm:gap-5 bg-transparent px-0 py-0 text-white transition" aria-label="Primary navigation">
          <a href="/" class="inline-flex rounded">
            <Image src={logo} alt="ACC Building Performance" width={260} quality={100} class="site-logo h-12 w-auto object-contain" loading="eager" />
          </a>

          <div class="site-nav-links hidden items-center justify-center gap-8 font-extrabold lg:flex">
              <!--<a href="/" class="transition">Home</a>-->
              <div class="group relative py-3">
                <button class="uppercase flex items-center gap-1 font-extrabold transition" type="button">
                  Services
                  <ChevronDown class="h-4 w-4" />
                </button>
                <div class="invisible absolute left-0 top-full w-72 translate-y-2 rounded-2xl border border-[#d5ded9] bg-white p-2 opacity-0 shadow-2xl shadow-black/15 transition group-hover:visible group-hover:translate-y-0 group-hover:opacity-100">
                  {servicesNav.map((item) => (
                    <a href={item.href} class="service-dropdown-link block rounded-xl px-4 py-3 text-sm font-extrabold hover:bg-[#edf4f4]">
                      {item.label}
                    </a>
                  ))}
                </div>
              </div>
              <a href="/about" class="uppercase transition">About</a>
              <a href="/blog" class="uppercase transition">Blog</a>
              <div class="group relative py-3">
                <button class="uppercase flex items-center gap-1 font-extrabold transition" type="button">
                  Resources
                  <ChevronDown class="h-4 w-4" />
                </button>
                <div class="invisible absolute left-0 top-full w-52 translate-y-2 rounded-2xl border border-[#d5ded9] bg-white p-2 opacity-0 shadow-2xl shadow-black/15 transition group-hover:visible group-hover:translate-y-0 group-hover:opacity-100">
                  <a href="/resources" class="service-dropdown-link block rounded-xl px-4 py-3 text-sm font-extrabold hover:bg-[#edf4f4]">Videos</a>
                  <a href="/resources/products" class="service-dropdown-link block rounded-xl px-4 py-3 text-sm font-extrabold hover:bg-[#edf4f4]">Products</a>
                </div>
              </div>
              <a href="/contact" class="uppercase transition">Contact</a>
          </div>

          <div class="ml-auto flex items-center justify-end gap-3">
            <a href="/contact" class="uppercase site-nav-cta btn-primary hidden min-h-12 px-6 text-sm lg:inline-flex">
              Book Your Assessment
            </a>
            <a href="tel:+15042480186" class="site-nav-cta btn-primary h-12 w-12 min-h-12 rounded-full p-0 text-sm lg:hidden" aria-label="Call ACC Building Performance">
              <Phone class="h-5 w-5" />
            </a>
            <details class="relative lg:hidden">
              <summary class="site-menu-button flex h-11 w-11 cursor-pointer list-none items-center justify-center rounded-full border border-white/30 bg-white/10 text-white backdrop-blur">
                <Menu class="menu-icon-open h-5 w-5" />
                <X class="menu-icon-close hidden h-5 w-5" />
              </summary>
              <div class="mobile-menu-panel fixed left-0 right-0 top-24 max-h-[calc(100vh-6rem)] overflow-y-auto border-y border-[#d5ded9] bg-white p-4 text-[#02293c] shadow-2xl shadow-black/20">
                <a href="/" class="block rounded-xl px-4 py-3.5 text-base font-black text-[#315561] hover:bg-[#edf4f4] hover:text-[#0b4850]">Home</a>
                <div class="mobile-nav-group">
                  <div class="flex items-center gap-2">
                    <a href="/home-wellness-assessment" class="block flex-1 rounded-xl px-4 py-3.5 text-base font-black text-[#315561] hover:bg-[#edf4f4] hover:text-[#0b4850]">Services</a>
                    <button type="button" class="mobile-nav-toggle flex h-11 w-11 items-center justify-center rounded-full bg-[#eef6f6] text-[#0b4850]" aria-expanded="false" aria-label="Toggle services menu" data-mobile-toggle="services-menu">
                      <ChevronDown class="h-5 w-5 transition" />
                    </button>
                  </div>
                  <div id="services-menu" class="mobile-nav-submenu mt-1 hidden rounded-xl bg-[#e3efef] p-1">
                    {servicesNav.map((item) => (
                      <a href={item.href} class="block rounded-xl px-4 py-3.5 text-base font-black text-[#315561] hover:bg-white hover:text-[#0b4850]">{item.label}</a>
                    ))}
                  </div>
                </div>
                <a href="/about" class="block rounded-xl px-4 py-3.5 text-base font-black text-[#315561] hover:bg-[#edf4f4] hover:text-[#0b4850]">About</a>
                <a href="/blog" class="block rounded-xl px-4 py-3.5 text-base font-black text-[#315561] hover:bg-[#edf4f4] hover:text-[#0b4850]">Blog</a>
                <div class="mobile-nav-group">
                  <div class="flex items-center gap-2">
                    <a href="/resources" class="block flex-1 rounded-xl px-4 py-3.5 text-base font-black text-[#315561] hover:bg-[#edf4f4] hover:text-[#0b4850]">Resources</a>
                    <button type="button" class="mobile-nav-toggle flex h-11 w-11 items-center justify-center rounded-full bg-[#eef6f6] text-[#0b4850]" aria-expanded="false" aria-label="Toggle resources menu" data-mobile-toggle="resources-menu">
                      <ChevronDown class="h-5 w-5 transition" />
                    </button>
                  </div>
                  <div id="resources-menu" class="mobile-nav-submenu mt-1 hidden rounded-xl bg-[#e3efef] p-1">
                    <a href="/resources" class="block rounded-xl px-4 py-3.5 text-base font-black text-[#315561] hover:bg-white hover:text-[#0b4850]">Videos</a>
                    <a href="/resources/products" class="block rounded-xl px-4 py-3.5 text-base font-black text-[#315561] hover:bg-white hover:text-[#0b4850]">Products</a>
                  </div>
                </div>
                <a href="/contact" class="block rounded-xl px-4 py-3.5 text-base font-black text-[#315561] hover:bg-[#edf4f4] hover:text-[#0b4850]">Contact</a>
              </div>
            </details>
          </div>
        </nav>
      </header>

      <main>
        <slot />
      </main>

      <script>
        document.addEventListener('DOMContentLoaded', () => {
          const siteHeader = document.querySelector('.site-header');
          const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          const revealTargets = document.querySelectorAll('.reveal-body');
          const mobileNavToggles = document.querySelectorAll('[data-mobile-toggle]');

          const updateHeaderState = () => {
            if (!siteHeader) return;
            siteHeader.classList.toggle('is-scrolled', window.scrollY > 12);
          };

          updateHeaderState();
          window.addEventListener('scroll', updateHeaderState, { passive: true });

          mobileNavToggles.forEach((toggle) => {
            toggle.addEventListener('click', () => {
              const submenu = document.getElementById(toggle.getAttribute('data-mobile-toggle'));
              const isOpen = toggle.getAttribute('aria-expanded') === 'true';
              if (!submenu) return;

              toggle.setAttribute('aria-expanded', String(!isOpen));
              submenu.classList.toggle('hidden', isOpen);
              toggle.querySelector('svg')?.classList.toggle('rotate-180', !isOpen);
            });
          });

          revealTargets.forEach((element, index) => {
            element.classList.add('body-reveal');
            element.style.setProperty('--reveal-delay', `${Math.min(index % 5, 4) * 55}ms`);
          });

          if (prefersReducedMotion || !('IntersectionObserver' in window)) {
            revealTargets.forEach((element) => element.classList.add('is-visible'));
            return;
          }

          const observer = new IntersectionObserver(
            (entries, revealObserver) => {
              entries.forEach((entry) => {
                if (!entry.isIntersecting) return;
                entry.target.classList.add('is-visible');
                revealObserver.unobserve(entry.target);
              });
            },
            { rootMargin: '0px 0px -8% 0px', threshold: 0.08 }
          );

          revealTargets.forEach((element) => observer.observe(element));
        });
      </script>

      <footer class="bg-acc-mist px-0 py-0 sm:px-6 sm:py-8 lg:px-8">
        <section class="relative overflow-hidden rounded-none bg-[#06333a] px-6 py-12 text-white shadow-2xl shadow-[#02293c]/15 sm:rounded-[2rem] sm:px-8 lg:px-12 lg:py-16">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_16%_12%,rgba(134,200,220,0.18),transparent_30rem),linear-gradient(135deg,#06333a_0%,#0b4850_58%,#02293c_100%)]"></div>
          <div class="hero-noise absolute inset-0 opacity-45"></div>
          <div class="relative z-10 mx-auto max-w-6xl">
            <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-end">
              <div>
                <Image src={logo} alt="ACC Building Performance" width={260} quality={100} class="h-12 w-auto" />
                <p class="mt-8 text-[0.68rem] font-black uppercase tracking-[0.3em] text-[#65b6ca]">Contact Us</p>
                <h2 class="mt-4 max-w-xl text-4xl font-black leading-[1.04] tracking-tight sm:text-5xl">
                  Ready for answers about your home?
                </h2>
              </div>
              <p class="max-w-2xl text-base font-semibold leading-7 text-white/64 lg:justify-self-end">
                ACC Building Performance serves Louisiana, Mississippi, Alabama, and the surrounding Gulf South with building science assessments, testing, and healthy home consulting.
              </p>
            </div>

            <div class="mt-12 grid gap-4 md:grid-cols-3">
              <a href="/contact" class="group rounded-2xl border border-white/12 bg-white/[0.045] p-6 transition hover:-translate-y-0.5 hover:bg-white/[0.08]">
                <MapPin class="h-7 w-7 text-[#8fc8d5]" />
                <h3 class="mt-5 text-xl font-black">Service Area</h3>
                <p class="mt-3 text-sm font-bold leading-6 text-white/58">Louisiana, Mississippi, Alabama & Gulf South Region</p>
              </a>
              <a href="tel:+15042480186" class="group rounded-2xl border border-white/12 bg-white/[0.045] p-6 transition hover:-translate-y-0.5 hover:bg-white/[0.08]">
                <Phone class="h-7 w-7 text-[#8fc8d5]" />
                <h3 class="mt-5 text-xl font-black">504-248-0186</h3>
                <p class="mt-3 text-sm font-bold leading-6 text-white/58">Call or text to start the conversation.</p>
              </a>
              <div class="rounded-2xl border border-white/12 bg-white/[0.045] p-6">
                <Clock3 class="h-7 w-7 text-[#8fc8d5]" />
                <h3 class="mt-5 text-xl font-black">Working Hours</h3>
                <p class="mt-3 text-sm font-bold leading-6 text-white/58">Monday-Friday: 8:30am-4:30pm</p>
              </div>
            </div>

            <div class="grid gap-8 pt-8 lg:mt-12 lg:border-t lg:border-white/10 lg:grid-cols-[1fr_auto] lg:items-center">
              <div>
                <div class="mt-4 flex flex-wrap justify-center gap-3 lg:justify-start">
                  <a href="#" class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-white/12 text-white/70 transition hover:border-white/35 hover:text-white" aria-label="Facebook">
                    <Facebook class="h-4 w-4" />
                  </a>
                  <a href="https://www.youtube.com/@ac-supercool" target="_blank" rel="noreferrer" class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-white/12 text-white/70 transition hover:border-white/35 hover:text-white" aria-label="YouTube">
                    <Youtube class="h-4 w-4" />
                  </a>
                  <a href="#" class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-white/12 text-white/70 transition hover:border-white/35 hover:text-white" aria-label="Instagram">
                    <Instagram class="h-4 w-4" />
                  </a>
                  <a href="#" class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-white/12 text-white/70 transition hover:border-white/35 hover:text-white" aria-label="LinkedIn">
                    <Linkedin class="h-4 w-4" />
                  </a>
                </div>
              </div>

              <nav class="hidden flex-wrap gap-x-7 gap-y-3 text-sm font-black text-white/62 lg:flex lg:justify-end" aria-label="Footer navigation">
                <a href="/" class="hover:text-white">Home</a>
                <a href="/about" class="hover:text-white">About</a>
                <a href="/home-wellness-assessment" class="hover:text-white">Services</a>
                <a href="/blog" class="hover:text-white">Blog</a>
                <a href="/resources" class="hover:text-white">Resources</a>
                <a href="/contact" class="hover:text-white">Contact</a>
              </nav>
            </div>

            <div class="mt-8 flex flex-col items-center gap-3 border-t border-white/10 pt-6 text-center text-xs font-bold text-white/38 sm:flex-row sm:items-center sm:justify-between sm:text-left">
              <p>Copyright © ACC Building Performance 2026</p>
              <p class="flex flex-col items-center gap-3 sm:flex-row sm:flex-wrap sm:gap-1.5">
                <span class="text-[#8fc8d5]">Colossians 3:23</span>
                <span class="hidden sm:inline">•</span>
                <a href="https://teamrileyweb.com/" target="_blank" rel="noreferrer" class="inline-flex items-center gap-1.5 text-white/62 transition hover:text-white">
                  <span>Crafted with</span>
                  <Heart class="h-3.5 w-3.5 fill-[#8fc8d5] text-[#8fc8d5]" />
                  <span>by Team Riley</span>
                </a>
              </p>
            </div>
          </div>
        </section>
      </footer>
    </div>
  </body>
</html>
