---
import { Image } from 'astro:assets';
import { ArrowLeft, ArrowRight, Gauge, Home as HomeIcon, Wind, Youtube } from '@lucide/astro';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { blogPosts } from '../../content/site';
import moldImage from '../../assets/images/imgi_241_premium_photo-1661957645816-099827ce621f.jpeg';
import hvacImage from '../../assets/images/pexels-jose-andres-pacheco-cortes-3641213-6471913.jpg';
import assessmentImage from '../../assets/images/imgi_298_premium_photo-1661964387248-55856fa89031.jpeg';
import builderImage from '../../assets/images/imgi_226_premium_photo-1677782977189-d2ba571a679c.jpeg';
import ajImage from '../../assets/images/aj-callegan.jpg';
import sprayFoamImage from '../../assets/images/imgi_284_premium_photo-1682148134234-772b74827e56.jpeg';
import buzzwordImage from '../../assets/images/building-science-buzzword.jpg';
import marignyRendering from '../../assets/images/marigny-rendering.png';
import constructionFrameImage from '../../assets/images/imgi_326_premium_photo-1683121688597-9f8e71d9d307.jpeg';
import hvacHealthImpactImage from '../../assets/images/hvac-health-impact.jpg';

export function getStaticPaths() {
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const blogImages = {
  'your-ac-company-has-more-impact-on-your-health-than-you-think': {
    src: hvacHealthImpactImage,
    alt: 'HVAC professional responsible for indoor air and system performance',
  },
  'code-is-not-a-quality-standard': {
    src: constructionFrameImage,
    alt: 'New home framing under construction before performance details are completed',
  },
  'if-the-budget-is-tight-shrink-the-house': {
    src: marignyRendering,
    alt: 'Custom home rendering representing design and budget decisions',
  },
  'building-science-is-not-a-buzzword': {
    src: buzzwordImage,
    alt: 'Building professional reviewing residential construction drawings',
  },
  'why-all-the-hate-on-spf-insulation': {
    src: sprayFoamImage,
    alt: 'Spray foam insulation installed in a building assembly',
  },
  'same-science-better-pacing-more-compassion': {
    src: ajImage,
    alt: 'AJ Callegan of ACC Building Performance',
  },
  'great-builder-protects-home-from-bad-decisions': {
    src: builderImage,
    alt: 'Custom home framing under construction before building science details are finalized',
  },
  'why-mold-keeps-coming-back': {
    src: moldImage,
    alt: 'Building professional inspecting insulation and moisture conditions',
  },
  'oversized-hvac-gulf-south-humidity': {
    src: hvacImage,
    alt: 'HVAC technician checking system pressure gauges',
  },
  'what-building-science-assessment-looks-for': {
    src: assessmentImage,
    alt: 'Building professional inspecting ducts and attic conditions',
  },
};
const categoryConfig = {
  'Building Science': { icon: Gauge },
  'Home Wellness': { icon: HomeIcon },
  'HVAC Design': { icon: Wind },
};
const articleImage = blogImages[post.slug];
const category = categoryConfig[post.category] ?? categoryConfig['Building Science'];
const CategoryIcon = category.icon;
---

<SiteLayout
  title={`${post.title} | ACC Building Performance`}
  description={post.excerpt}
>
  <article>
    <section class="hero-airflow hero-noise relative isolate overflow-hidden bg-[#0b4850] px-5 pb-20 pt-36 text-white sm:px-6 lg:px-8 lg:pb-24 lg:pt-40">
      <div class="relative z-10 mx-auto grid max-w-6xl items-center gap-12 lg:grid-cols-[1fr_0.82fr]">
        <div class="text-center lg:text-left">
          <a href="/blog" class="reveal-body inline-flex items-center gap-2 text-sm font-black text-white/62 transition hover:text-white">
            <ArrowLeft class="h-4 w-4" />
            Back to Blog
          </a>
          <p class="mt-10 flex items-center justify-center gap-3 text-[0.72rem] font-extrabold uppercase tracking-[0.28em] text-[#86c8dc] lg:justify-start">
            <CategoryIcon class="h-4 w-4" />
            <span>{post.category} · {post.readTime}</span>
          </p>
          <h1 class="mt-4 text-5xl font-extrabold leading-[1.05] tracking-normal text-white sm:mt-8 sm:text-7xl">{post.title}</h1>
          <p class="reveal-body mt-4 max-w-3xl text-lg font-medium leading-8 text-white/70 sm:mt-8">{post.excerpt}</p>
        </div>
        <div class="reveal-body overflow-hidden rounded-2xl border border-white/10 bg-[#0f545e] shadow-2xl shadow-black/20">
          <Image src={articleImage.src} alt={articleImage.alt} width={760} class="aspect-[1.02] w-full object-cover" loading="eager" />
        </div>
      </div>
    </section>

    <section class="bg-acc-mist px-5 py-20 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <div class="grid gap-14">
          {post.body.map((section) => (
            <section class="reveal-body">
              <h2 class="text-3xl font-black leading-tight text-acc-ink sm:text-4xl">{section.heading}</h2>
              <div class="mt-6 grid gap-5 text-lg font-semibold leading-8 text-[#164f59]/85">
                {section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
              </div>
            </section>
          ))}
        </div>

        {post.resourceLink && (
          <a href={post.resourceLink.href} target="_blank" rel="noreferrer" class="reveal-body mt-14 flex flex-col gap-5 rounded-3xl border border-[#d5ded9] bg-white p-7 shadow-sm transition hover:-translate-y-0.5 hover:border-[#9fcbd0] hover:shadow-xl hover:shadow-slate-950/7 sm:flex-row sm:items-center sm:justify-between">
            <span class="flex items-start gap-5">
              <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-[#0b4850] text-white">
                <Youtube class="h-6 w-6" />
              </span>
              <span>
                <span class="block text-sm font-black uppercase tracking-[0.22em] text-[#62aebe]">Recommended Resource</span>
                <span class="mt-3 block text-2xl font-black leading-tight text-acc-ink">{post.resourceLink.label}</span>
                <span class="mt-3 block text-base font-semibold leading-7 text-[#164f59]/80">{post.resourceLink.description}</span>
              </span>
            </span>
            <span class="inline-flex w-fit items-center gap-2 text-sm font-black text-[#0b4850]">
              Open YouTube
              <ArrowRight class="h-4 w-4" />
            </span>
          </a>
        )}

        <div class="reveal-body mt-16 rounded-3xl bg-[#06333a] p-8 text-white shadow-2xl shadow-[#06333a]/20 sm:p-10">
          <h2 class="text-3xl font-black leading-tight">Need answers about your home?</h2>
          <p class="mt-4 max-w-2xl text-base font-semibold leading-7 text-white/68">
            ACC Building Performance is local to the Gulf South and serves the entire United States, finding and documenting the root cause of moisture, mold, HVAC, and indoor air quality problems.
          </p>
          <a href="/contact" class="btn-primary mt-7">
            Book Your Assessment
            <ArrowRight class="h-5 w-5" />
          </a>
        </div>
      </div>
    </section>
  </article>
</SiteLayout>
