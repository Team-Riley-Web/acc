---
import { Image } from 'astro:assets';
import { ArrowLeft, ArrowRight } from '@lucide/astro';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { blogPosts } from '../../content/site';
import moldImage from '../../assets/images/imgi_241_premium_photo-1661957645816-099827ce621f.jpeg';
import hvacImage from '../../assets/images/pexels-jose-andres-pacheco-cortes-3641213-6471913.jpg';
import assessmentImage from '../../assets/images/imgi_298_premium_photo-1661964387248-55856fa89031.jpeg';

export function getStaticPaths() {
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const blogImages = {
  'why-mold-keeps-coming-back': {
    src: moldImage,
    alt: 'Building professional inspecting insulation and moisture conditions',
  },
  'oversized-hvac-gulf-south-humidity': {
    src: hvacImage,
    alt: 'HVAC technician checking system pressure gauges',
  },
  'what-building-science-assessment-looks-for': {
    src: assessmentImage,
    alt: 'Building professional inspecting ducts and attic conditions',
  },
};
const articleImage = blogImages[post.slug];
---

<SiteLayout
  title={`${post.title} | ACC Building Performance`}
  description={post.excerpt}
>
  <article>
    <section class="hero-airflow hero-noise relative isolate overflow-hidden bg-[#0b4850] px-5 pb-20 pt-36 text-white sm:px-6 lg:px-8 lg:pb-24 lg:pt-40">
      <div class="relative z-10 mx-auto grid max-w-6xl items-center gap-12 lg:grid-cols-[1fr_0.82fr]">
        <div class="text-center lg:text-left">
          <a href="/blog" class="reveal-body inline-flex items-center gap-2 text-sm font-black text-white/62 transition hover:text-white">
            <ArrowLeft class="h-4 w-4" />
            Back to Blog
          </a>
          <p class="mt-10 text-[0.72rem] font-extrabold uppercase tracking-[0.28em] text-[#86c8dc]">{post.category} · {post.readTime}</p>
          <h1 class="mt-4 text-5xl font-extrabold leading-[1.05] tracking-normal text-white sm:mt-8 sm:text-7xl">{post.title}</h1>
          <p class="reveal-body mt-4 max-w-3xl text-lg font-medium leading-8 text-white/70 sm:mt-8">{post.excerpt}</p>
        </div>
        <div class="reveal-body overflow-hidden rounded-2xl border border-white/10 bg-[#0f545e] shadow-2xl shadow-black/20">
          <Image src={articleImage.src} alt={articleImage.alt} width={760} class="aspect-[1.02] w-full object-cover" loading="eager" />
        </div>
      </div>
    </section>

    <section class="bg-acc-mist px-5 py-20 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <div class="grid gap-14">
          {post.body.map((section) => (
            <section class="reveal-body">
              <h2 class="text-3xl font-black leading-tight text-acc-ink sm:text-4xl">{section.heading}</h2>
              <div class="mt-6 grid gap-5 text-lg font-semibold leading-8 text-[#164f59]/85">
                {section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
              </div>
            </section>
          ))}
        </div>

        <div class="reveal-body mt-16 rounded-3xl bg-[#06333a] p-8 text-white shadow-2xl shadow-[#06333a]/20 sm:p-10">
          <h2 class="text-3xl font-black leading-tight">Need answers about your home?</h2>
          <p class="mt-4 max-w-2xl text-base font-semibold leading-7 text-white/68">
            ACC Building Performance finds and documents the root cause of moisture, mold, HVAC, and indoor air quality problems across the Gulf South.
          </p>
          <a href="/contact" class="btn-primary mt-7">
            Book Your Assessment
            <ArrowRight class="h-5 w-5" />
          </a>
        </div>
      </div>
    </section>
  </article>
</SiteLayout>
