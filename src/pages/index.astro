---
import { Image } from 'astro:assets';
import {
    Activity,
    ArrowRight,
    Check,
    CheckCircle2,
    ClipboardList,
    Clock3,
    Droplets,
    Home,
    Mail,
    MapPin,
    Search,
    ShieldCheck,
    Utensils,
    Wind,
} from '@lucide/astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import ajCallegan from '../assets/images/aj-callegan.jpg';
import marignyRendering from '../assets/images/marigny-rendering.png';

const heroImage = 'https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?auto=format&fit=crop&w=1500&q=85';

const stats = [
    { value: '20+', label: 'Years in HVAC & construction', icon: Clock3 },
    { value: '10', label: 'Building science specialties', icon: Home },
    { value: '4', label: 'ACCA Manuals - J, S, D & T', icon: Activity },
    { value: '100%', label: 'Verified results', icon: CheckCircle2 },
];

const services = [
    {
        eyebrow: '01 - For Existing Homes',
        title: 'Home Performance Assessment',
        copy: 'A science-based diagnostic that uncovers hidden factors affecting your home’s health, comfort, and durability. Not a checklist - a real investigation.',
        href: '/home-wellness-assessment',
        image: marignyRendering.src,
        bullets: ['Thermal imaging & moisture mapping', 'Static & zonal pressure diagnostics', 'IAQ monitoring snapshot', 'On-site assessment + comprehensive report'],
    },
    {
        eyebrow: '02 - For Custom Builders',
        title: 'Healthy Home Consulting Package',
        copy: 'Expert design and oversight from pre-construction through final sign-off. For builders who want more than code compliance.',
        href: '/healthy-home-consulting',
        image: 'https://images.unsplash.com/photo-1503387762-592deb58ef4e?auto=format&fit=crop&w=900&q=80',
        bullets: ['Design & trade coordination', 'Full ACCA Manual J, S, D & T HVAC', 'Blower door and duct leakage testing', 'Documentation and ongoing support'],
    },
    {
        eyebrow: '03 - Design & Testing',
        title: 'Precision HVAC Design Services',
        copy: 'Precision engineering for high-performance HVAC systems. Load calculations, equipment selection, ductwork design, and verification.',
        href: '/hvac-design',
        image: 'https://images.unsplash.com/photo-1621905252507-b35492cc74b4?auto=format&fit=crop&w=900&q=80',
        bullets: ['ACCA Manual J load calculations', 'Manual S equipment selection', 'Manual D ductwork design', 'Blower door and duct leakage testing'],
    },
];
---

<SiteLayout
        title="ACC Building Performance | Root-Cause Building Science Assessments"
        description="ACC Building Performance finds the root cause of mold, moisture, and indoor air quality problems in Gulf South homes. Building science assessments that find what others miss."
>
    <section class="hero-airflow hero-noise relative isolate overflow-hidden bg-[#0b4850] px-5 pb-28 pt-28 text-white sm:px-6 lg:px-8 lg:pb-32 lg:pt-36">
        <div class="relative z-10 mx-auto grid max-w-6xl items-center gap-16 lg:grid-cols-[1fr_1.05fr]">
            <div>
                <p class="text-[0.72rem] font-extrabold uppercase tracking-[0.22em] text-[#86c8dc] sm:tracking-[0.28em]">Building Science · HVAC Consulting</p>
                <h1 class="mt-9 max-w-xl text-5xl font-extrabold leading-[1.05] tracking-normal text-white sm:text-[5.1rem] lg:text-[5.75rem]">
                    Home
                    <span class="block bg-gradient-to-b from-[#9edcea] to-[#8ca0de] bg-clip-text text-transparent">Air You Can Trust.</span>
                </h1>
                <p class="reveal-body mt-9 max-w-xl text-lg font-medium leading-8 text-white/70">
                    ACC Building Performance is a building science specialist serving the Gulf South. We find the root cause of what is making your home, and your family, sick.
                </p>
                <div class="reveal-body mt-12 flex flex-wrap gap-5">
                    <a href="/contact" class="btn-primary">Schedule an Assessment</a>
                    <a href="/about" class="btn-secondary-dark">Our Story</a>
                </div>
            </div>

            <div class="relative mx-auto w-full max-w-xl lg:mx-0 lg:justify-self-end">
                <div class="reveal-body overflow-hidden rounded-2xl border border-white/10 bg-[#0f545e] shadow-2xl shadow-black/20">
                    <img src={heroImage} alt="Modern high-performance home exterior at dusk" class="aspect-[1.02] w-full object-cover" loading="eager" />
                </div>
                <div class="reveal-body absolute -bottom-5 left-1/2 flex w-[86%] max-w-sm -translate-x-1/2 items-center gap-5 rounded-2xl bg-white p-5 text-[#02293c] shadow-2xl sm:-bottom-9 sm:left-24 sm:translate-x-0">
          <span class="flex h-16 w-16 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-[#9fd5e1] to-[#6b81bf] text-white">
            <Search class="h-9 w-9" />
          </span>
                    <span>
            <span class="block text-base font-black leading-tight text-[#02293c]">Root-Cause Diagnostics</span>
            <span class="mt-1 block text-sm font-bold leading-5 text-slate-600">Not a checklist - a real investigation</span>
          </span>
                </div>
            </div>
        </div>
    </section>

    <section class="relative bg-[#06333a] px-5 py-10 text-white sm:px-6 lg:px-8">
        <div class="absolute inset-x-[-8%] -bottom-12 h-32 rounded-[0_0_50%_50%] bg-[#06333a]"></div>
        <div class="relative mx-auto grid max-w-6xl gap-8 md:grid-cols-4">
            {stats.map(({ value, label, icon: Icon }) => (
                    <article class="reveal-body border-white/10 md:border-l md:px-8 first:md:border-l-0">
                        <Icon class="mb-6 h-7 w-7 text-[#6ab8ce]" />
                        <p class="text-5xl font-black tracking-tight">{value}</p>
                        <p class="mt-2 max-w-[11rem] text-xs font-bold leading-5 text-white/75">{label}</p>
                    </article>
            ))}
        </div>
    </section>

    <section class="relative bg-acc-mist px-5 pb-28 pt-28 sm:px-6 lg:px-8 lg:pt-36">
        <div class="mx-auto grid max-w-6xl items-stretch gap-16 lg:grid-cols-[0.9fr_1fr]">
            <div class="relative mx-auto w-full max-w-lg lg:mx-0 lg:max-w-none">
                <div class="reveal-body h-full min-h-[34rem] overflow-hidden rounded-2xl shadow-2xl shadow-[#06333a]/15">
                    <Image src={ajCallegan} alt="AJ Callegan, founder of ACC Building Performance" width={760} class="aspect-[4/5] h-full w-full object-cover object-bottom lg:aspect-auto" />
                </div>
            </div>
            <div>
                <p class="text-[0.68rem] font-black uppercase tracking-[0.3em] text-[#4f93a2]">The Story Behind ACC</p>
                <h2 class="mt-5 max-w-xl text-5xl font-black leading-[1.02] tracking-tight text-acc-ink sm:text-6xl">A personal health crisis became a professional mission.</h2>
                <div class="reveal-body mt-8 grid max-w-2xl gap-5 text-base font-semibold leading-7 text-[#164f59]/85">
                    <p>AJ founded ACC Building Performance because he saw the same story playing out over and over: families suffering in homes that had been inspected, remediated, and serviced by a dozen different contractors, and still sick.</p>
                    <p>In 2022, he launched ACC Building Performance as a direct response to the construction deficiencies that nearly destroyed his health.</p>
                </div>
                <a href="/about" class="reveal-body mt-9 inline-flex min-h-12 items-center gap-2 rounded-full bg-[#02293c] px-7 text-sm font-extrabold text-white shadow-sm transition hover:bg-[#092f38]">
                    Learn More About AJ
                    <ArrowRight class="h-4 w-4" />
                </a>
            </div>
        </div>
    </section>

    <section class="relative bg-[#06333a] px-5 py-10 text-white sm:px-6 lg:px-8">
        <div class="absolute inset-x-[-8%] -bottom-12 h-32 rounded-[0_0_50%_50%] bg-[#06333a]"></div>
        <div class="reveal-body relative mx-auto flex max-w-6xl flex-wrap justify-center gap-x-16 gap-y-4 text-sm font-black text-white/78">
            <span>✓ Building Science Certified</span>
            <span>✓ Trusted by Functional Medicine Doctors</span>
            <span>✓ Root-Cause Methodology</span>
        </div>
    </section>

    <section id="how-we-work" class="relative bg-[linear-gradient(135deg,#0b4850_0%,#073942_48%,#02293c_100%)] px-5 py-28 text-white sm:px-6 lg:px-8">
        <div class="hero-noise absolute inset-0 opacity-70"></div>
        <div class="relative mx-auto max-w-6xl">
            <!--<p class="text-[0.68rem] font-black uppercase tracking-[0.3em] text-[#65b6ca]">What We Do</p>-->
            <h2 class="mt-5 max-w-2xl text-5xl font-black leading-none tracking-tight sm:text-6xl">Building Science.<br />Not Guesswork.</h2>
            <div class="reveal-body mt-8 grid max-w-3xl gap-5 text-base font-semibold leading-7 text-white/75">
                <p>Building science is the discipline of evaluating a home as an integrated system: the envelope, the mechanical systems, the moisture dynamics, and how they interact. We conduct comprehensive assessments that trace the problem back to its source, then document what was found, why it matters, and what needs to happen next.</p>
            </div>
            <div class="mt-14 grid overflow-hidden rounded-xl border border-white/12 md:grid-cols-3">
                {[
                    [Search, 'Root-Cause Investigation', "We don't describe symptoms. We find the building deficiency that created them.", '/home-wellness-assessment'],
                    [ClipboardList, 'Documented & Actionable', 'Every assessment produces a written report you can hand to your doctor, contractor, and insurance company.', '/home-wellness-assessment'],
                    [Home, 'Whole-Home Perspective', 'We evaluate the envelope, mechanical systems, moisture management, and their interactions.', '/healthy-home-consulting'],
                ].map(([Icon, title, copy, href]) => (
                        <a href={href} class="reveal-body group flex min-h-64 flex-col border-b border-r border-white/12 bg-white/[0.025] p-7 transition hover:bg-white/[0.07]">
                            <div class="mb-8 flex h-10 w-10 items-center justify-center rounded-lg border border-white/12 bg-white/[0.06] text-[#6ab8ce] shadow-[inset_0_1px_0_rgba(255,255,255,0.08)]">
                                <Icon class="h-5 w-5" />
                            </div>
                            <h3 class="text-xl font-black leading-tight">{title}</h3>
                            <p class="mt-3 text-sm font-semibold leading-6 text-white/50">{copy}</p>
                            <span class="mt-auto inline-flex w-fit items-center gap-2 pt-8 text-sm font-black text-[#8fd1df] transition group-hover:text-white">
                                Learn More
                                <ArrowRight class="h-4 w-4 transition group-hover:translate-x-0.5" />
                            </span>
                        </a>
                ))}
            </div>
        </div>
    </section>

    <section class="relative bg-acc-mist px-5 py-20 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-6xl">
            <p class="text-[0.68rem] font-black uppercase tracking-[0.3em] text-[#62aebe]">What We Do</p>
            <h2 class="mt-4 max-w-2xl text-5xl font-black leading-none tracking-tight text-acc-ink sm:text-6xl">Who We Help</h2>
            <p class="reveal-body mt-6 max-w-3xl text-base font-semibold leading-7 text-[#164f59]/85">Whether your family is sick in a home you've lived in for years, or you're building a new home and want to get it right from the start, ACC Building Performance has a service built for your situation.</p>
            <div class="mt-14 grid gap-6 lg:grid-cols-3">
                {services.map((service) => (
                        <a href={service.href} class="reveal-body group flex overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm transition hover:-translate-y-0.5 hover:border-[#9fcbd0] hover:shadow-xl hover:shadow-slate-950/7">
                            <div class="flex w-full flex-col">
                                <img src={service.image} alt="" class="h-44 w-full object-cover" loading="lazy" />
                                <div class="flex flex-1 flex-col p-7">
                                    <p class="text-[0.68rem] font-black uppercase tracking-[0.24em] text-[#62aebe]">{service.eyebrow}</p>
                                    <h3 class="mt-4 text-2xl font-black leading-tight text-acc-ink">{service.title}</h3>
                                    <p class="mt-4 text-sm font-semibold leading-6 text-slate-500">{service.copy}</p>
                                    <ul class="my-6 grid gap-3 text-sm font-bold leading-6 text-slate-700">
                                        {service.bullets.map((bullet) => (
                                            <li class="flex gap-3"><Check class="mt-1 h-4 w-4 shrink-0 text-[#62aebe]" /><span>{bullet}</span></li>
                                        ))}
                                    </ul>
                                    <span class="mt-auto inline-flex min-h-11 w-fit items-center gap-2 rounded-full bg-[#0b4850] px-5 text-sm font-black text-white shadow-sm transition group-hover:bg-[#08717f]">
                                        Learn More
                                        <ArrowRight class="h-4 w-4 transition group-hover:translate-x-0.5" />
                                    </span>
                                </div>
                            </div>
                        </a>
                ))}
            </div>
        </div>
    </section>

    <section class="bg-acc-mist px-5 pb-16 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-7xl rounded-3xl bg-[#06333a] px-8 py-14 text-white shadow-2xl shadow-[#06333a]/25 ring-1 ring-white/10 sm:px-12 lg:px-20 lg:py-24">
            <div class="grid gap-14 lg:grid-cols-2 lg:items-center">
                <div>
                    <h2 class="max-w-sm text-6xl font-black leading-[1.02] tracking-tight sm:text-6xl">Where breath becomes the baseline.</h2>
                    <p class="reveal-body mt-7 max-w-md text-base font-semibold leading-7 text-white/70">
                        The rule of 3 is simple: food buys weeks, water buys days, air buys minutes. That makes indoor air quality a first-order home performance issue, not an afterthought.
                    </p>
                    <a href="/contact" class="btn-primary reveal-body mt-9">
                        Schedule an Assessment
                        <ArrowRight class="h-5 w-5" />
                    </a>
                </div>

                <div class="grid gap-10">
                    {[
                        [Utensils, '3 weeks', 'without food'],
                        [Droplets, '3 days', 'without water'],
                        [Wind, '3 minutes', 'without air'],
                    ].map(([Icon, value, label]) => (
                            <article class="reveal-body grid gap-6 sm:grid-cols-[7rem_1fr] sm:items-center">
                                <Icon class="h-20 w-20 text-[#8fc8d5]" stroke-width={1.5} />
                                <div>
                                    <p class="text-5xl font-black tracking-tight sm:text-7xl">{value}</p>
                                    <p class="mt-2 text-lg font-black text-white/55">{label}</p>
                                </div>
                            </article>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <section id="contact" class="bg-acc-mist px-5 pb-24 pt-12 sm:px-6 lg:px-8">
        <div class="mx-auto grid max-w-6xl gap-10 rounded-2xl bg-white p-8 shadow-xl shadow-[#06333a]/10 lg:grid-cols-[0.8fr_1.2fr] lg:p-12">
            <div>
                <p class="text-[0.68rem] font-black uppercase tracking-[0.3em] text-[#62aebe]">Contact</p>
                <h2 class="mt-4 text-4xl font-black leading-tight text-acc-ink">Ready to diagnose your home, not guess?</h2>
                <div class="reveal-body mt-8 grid gap-4 text-sm font-bold text-slate-600">
                    <p class="flex items-center gap-3"><MapPin class="h-5 w-5 text-[#62aebe]" /> Covington, Louisiana</p>
                    <a href="tel:+15042480186" class="flex items-center gap-3 hover:text-acc-ink">504-248-0186</a>
                    <p class="flex items-center gap-3"><ShieldCheck class="h-5 w-5 text-[#62aebe]" /> Building science, HVAC design, and verification</p>
                </div>
            </div>

            <form name="contact" method="POST" data-netlify="true" netlify-honeypot="company" class="reveal-body grid gap-4">
                <input type="hidden" name="form-name" value="contact" />
                <p class="hidden">
                    <label>Company <input name="company" /></label>
                </p>
                <div class="grid gap-4 sm:grid-cols-2">
                    <input name="name" required placeholder="Name" aria-label="Name" class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-4 text-base font-semibold outline-none focus:ring-2 focus:ring-[#62aebe]" />
                    <input type="email" name="email" required placeholder="Email" aria-label="Email" class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-4 text-base font-semibold outline-none focus:ring-2 focus:ring-[#62aebe]" />
                </div>
                <textarea name="message" rows="5" required placeholder="What is happening in the home?" aria-label="Message" class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-4 text-base font-semibold outline-none focus:ring-2 focus:ring-[#62aebe]"></textarea>
                <button type="submit" class="inline-flex min-h-12 w-fit items-center gap-2 rounded-full bg-acc-ink px-7 text-sm font-extrabold text-white transition hover:bg-[#092f38]">
                    Send Message
                    <Mail class="h-4 w-4" />
                </button>
            </form>
        </div>
    </section>
</SiteLayout>
