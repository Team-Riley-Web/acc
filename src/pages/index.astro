      <!--      </article>-->
      <!--  ))}-->
      <!--</div>-->
    </div>
  </section>

  <!--<section id="projects" class="relative bg-[linear-gradient(135deg,#0b4850_0%,#073942_48%,#02293c_100%)] px-5 py-28 text-white sm:px-6 lg:px-8">-->
