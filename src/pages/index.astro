  <section class="relative bg-acc-mist px-5 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <p class="text-[0.68rem] font-black uppercase tracking-[0.3em] text-[#62aebe]">What We Do</p>
      <h2 class="mt-4 max-w-2xl text-5xl font-black leading-none tracking-tight text-acc-ink sm:text-6xl">Who We Help</h2>
      <p class="mt-6 max-w-3xl text-base font-semibold leading-7 text-[#164f59]/85">Whether your family is sick in a home you've lived in for years, or you're building a new home and want to get it right from the start, ACC Building Performance has a service built for your situation.</p>
      <div class="mt-14 grid gap-6 lg:grid-cols-3">
        {services.map((service) => (
            <article class="flex overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
              <div class="flex w-full flex-col">
                <img src={service.image} alt="" class="h-44 w-full object-cover" loading="lazy" />
                <div class="flex flex-1 flex-col p-7">
                  <p class="text-[0.68rem] font-black uppercase tracking-[0.24em] text-[#62aebe]">{service.eyebrow}</p>
                  <h3 class="mt-4 text-2xl font-black leading-tight text-acc-ink">{service.title}</h3>
                  <p class="mt-4 text-sm font-semibold leading-6 text-slate-500">{service.copy}</p>
                  <ul class="mt-6 grid gap-3 text-sm font-bold leading-6 text-slate-700">
                    {service.bullets.map((bullet) => (
                        <li class="flex gap-3"><Check class="mt-1 h-4 w-4 shrink-0 text-[#62aebe]" /><span>{bullet}</span></li>
                    ))}
                  </ul>
                </div>
              </div>
            </article>
        ))}
      </div>
    </div>
  </section>

