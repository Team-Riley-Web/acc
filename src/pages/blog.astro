---
import { Image } from 'astro:assets';
import { ArrowRight, BookOpen } from '@lucide/astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import { blogPosts } from '../content/site';
import moldImage from '../assets/images/imgi_241_premium_photo-1661957645816-099827ce621f.jpeg';
import hvacImage from '../assets/images/pexels-jose-andres-pacheco-cortes-3641213-6471913.jpg';
import assessmentImage from '../assets/images/imgi_298_premium_photo-1661964387248-55856fa89031.jpeg';

const blogImages = {
  'why-mold-keeps-coming-back': {
    src: moldImage,
    alt: 'Building professional inspecting insulation and moisture conditions',
  },
  'oversized-hvac-gulf-south-humidity': {
    src: hvacImage,
    alt: 'HVAC technician checking system pressure gauges',
  },
  'what-building-science-assessment-looks-for': {
    src: assessmentImage,
    alt: 'Building professional inspecting ducts and attic conditions',
  },
};
---

<SiteLayout
  title="Blog | ACC Building Performance"
  description="Building science articles from ACC Building Performance on mold, moisture, HVAC design, and healthy homes in the Gulf South."
>
  <section class="hero-airflow hero-noise relative isolate overflow-hidden bg-[#0b4850] px-5 pb-24 pt-36 text-white sm:px-6 lg:px-8 lg:pb-28 lg:pt-40">
    <div class="relative z-10 mx-auto grid max-w-6xl items-center gap-12 lg:grid-cols-[1fr_0.82fr]">
      <div class="text-center lg:text-left">
        <p class="text-[0.72rem] font-extrabold uppercase tracking-[0.28em] text-[#86c8dc]">ACCBP Blog</p>
        <h1 class="mt-4 max-w-4xl text-5xl font-extrabold leading-[1.05] tracking-normal text-white sm:mt-8 sm:text-7xl">
          Building Science Insights for Homes.
        </h1>
        <p class="reveal-body mt-4 max-w-2xl text-lg font-medium leading-8 text-white/70 sm:mt-8">
          Practical guidance on mold, moisture, HVAC design, and the building failures that affect indoor health across the Gulf South.
        </p>
      </div>
      <div class="reveal-body overflow-hidden rounded-2xl border border-white/10 bg-[#0f545e] shadow-2xl shadow-black/20">
        <Image src={assessmentImage} alt="Building professional inspecting attic ductwork" width={760} class="aspect-[1.02] w-full object-cover" loading="eager" />
      </div>
    </div>
  </section>

  <section class="bg-acc-mist px-5 py-24 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="grid gap-6 lg:grid-cols-3">
        {blogPosts.map((post) => (
          <article class="reveal-body group flex min-h-[24rem] flex-col rounded-2xl border border-[#d5ded9] bg-white p-7 shadow-sm transition hover:-translate-y-0.5 hover:border-[#9fcbd0] hover:shadow-xl hover:shadow-slate-950/7">
            <div class="-mx-7 -mt-7 mb-7 overflow-hidden rounded-t-2xl">
              <Image src={blogImages[post.slug].src} alt={blogImages[post.slug].alt} width={720} class="h-52 w-full object-cover transition duration-500 group-hover:scale-[1.03]" />
            </div>
            <div class="flex items-center gap-3 text-[0.68rem] font-black uppercase tracking-[0.24em] text-[#62aebe]">
              <BookOpen class="h-4 w-4" />
              {post.category}
            </div>
            <h2 class="mt-8 text-3xl font-black leading-tight text-acc-ink">{post.title}</h2>
            <p class="mt-5 text-base font-semibold leading-7 text-[#164f59]/80">{post.excerpt}</p>
            <div class="mt-auto flex items-center justify-between gap-5 pt-10">
              <span class="text-sm font-black text-slate-500">{post.readTime}</span>
              <a href={post.href} class="inline-flex items-center gap-2 text-sm font-black text-[#0b4850]">
                Read Article
                <ArrowRight class="h-4 w-4 transition group-hover:translate-x-0.5" />
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</SiteLayout>
