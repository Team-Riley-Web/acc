---
import { ArrowRight, Youtube } from '@lucide/astro';
import { XMLParser } from 'fast-xml-parser';
import ResourceTabs from '../components/ResourceTabs.astro';
import SiteLayout from '../layouts/SiteLayout.astro';

const channelUrl = 'https://www.youtube.com/@ac-supercool';
const channelId = 'UCh3H22ag2N2CVB9q1S6gkXw';
const feedUrl = `https://www.youtube.com/feeds/videos.xml?channel_id=${channelId}`;
const fallbackVideos = [
  {
    id: '--cZbL64xtk',
    title: 'Calhoun Crawlspace Tour',
    date: 'June 10, 2026',
    category: 'Crawlspace Inspection',
  },
  {
    id: '5WvRUnlGHus',
    title: 'STOP WASTING MONEY on Duct Cleaning GIMMICKS',
    date: 'April 16, 2026',
    category: 'Indoor Air Quality',
  },
  {
    id: 'bVC8hamcyvs',
    title: '1946 Balloon-Framed Home + Failed Asbestos Abatement',
    date: 'April 15, 2026',
    category: 'Building Science',
  },
  {
    id: 'VD7KiqyUsz8',
    title: 'Robot Crawlspace Tour: Severe Microbial Proliferation',
    date: 'April 4, 2026',
    category: 'Moisture & Mold',
  },
  {
    id: 'RDOHArbqVgY',
    title: 'Another Duct Cleaning Scam',
    date: 'March 31, 2026',
    category: 'HVAC Failure',
  },
  {
    id: 'Y2DUOGiliJc',
    title: 'No Air Barrier, No Moisture Control',
    date: 'March 31, 2026',
    category: 'Crawlspace Inspection',
  },
  {
    id: 'YSdEyQYVDRo',
    title: 'Health-Driven 3D Mechanical Design',
    date: 'January 24, 2026',
    category: 'HVAC Design',
  },
];

const categorizeVideo = (title) => {
  const normalizedTitle = title.toLowerCase();

  if (normalizedTitle.includes('duct') || normalizedTitle.includes('hvac')) return 'HVAC & Ductwork';
  if (normalizedTitle.includes('crawlspace')) return 'Crawlspace Inspection';
  if (normalizedTitle.includes('mold') || normalizedTitle.includes('microbial')) return 'Moisture & Mold';
  if (normalizedTitle.includes('design')) return 'HVAC Design';
  return 'Building Science';
};

const formatDate = (date) =>
  new Intl.DateTimeFormat('en-US', {
    month: 'long',
    day: 'numeric',
    year: 'numeric',
  }).format(new Date(date));

const getLatestVideos = async () => {
  try {
    const response = await fetch(feedUrl);

    if (!response.ok) {
      throw new Error(`YouTube feed responded with ${response.status}`);
    }

    const xml = await response.text();
    const parser = new XMLParser({
      ignoreAttributes: false,
      removeNSPrefix: true,
    });
    const feed = parser.parse(xml).feed;
    const entries = Array.isArray(feed.entry) ? feed.entry : [feed.entry].filter(Boolean);

    return entries.slice(0, 7).map((entry) => ({
      id: entry.videoId,
      title: entry.title,
      date: formatDate(entry.published),
      category: categorizeVideo(entry.title),
    }));
  } catch (error) {
    console.warn('Unable to fetch YouTube RSS feed for resources page:', error);
    return fallbackVideos;
  }
};

const videos = await getLatestVideos();
const latestVideo = videos[0];
const supportingVideos = videos.slice(1, 7);
---

<SiteLayout
  title="Resources | ACC Building Performance"
  description="Watch ACC Building Performance videos on crawlspaces, HVAC design, moisture control, indoor air quality, and building science."
>
  <section class="hero-airflow hero-noise relative isolate overflow-hidden bg-[#0b4850] px-5 pb-20 pt-36 text-white sm:px-6 lg:px-8 lg:pb-24 lg:pt-40">
    <div class="relative z-10 mx-auto grid max-w-6xl items-center gap-16 lg:grid-cols-[0.9fr_1.1fr]">
      <div class="text-center lg:text-left">
        <p class="flex items-center justify-center gap-3 text-[0.72rem] font-extrabold uppercase tracking-[0.28em] text-[#86c8dc] lg:justify-start">
          <Youtube class="h-5 w-5" />
          Resources
        </p>
        <h1 class="mt-4 max-w-3xl text-5xl font-extrabold leading-[1.05] tracking-normal text-white sm:mt-8 sm:text-7xl">Building Science Videos.</h1>
        <p class="reveal-body mt-4 max-w-2xl text-lg font-medium leading-8 text-white/70 sm:mt-8">
          Field documentation, HVAC design breakdowns, crawlspace tours, and indoor air quality lessons from ACCBP.
        </p>
      </div>

      <div class="reveal-body lg:relative">
        <div class="overflow-hidden rounded-2xl border border-white/10 bg-[#0f545e] shadow-2xl shadow-black/20">
          <iframe
            class="aspect-video w-full"
            src={`https://www.youtube-nocookie.com/embed/${latestVideo.id}`}
            title={latestVideo.title}
            loading="eager"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
          ></iframe>
        </div>
        <a href={channelUrl} target="_blank" rel="noreferrer" class="mx-auto mt-4 flex w-fit min-h-12 items-center justify-center gap-2 rounded-full bg-white px-6 text-sm font-black text-[#0b4850] shadow-2xl shadow-black/20 transition hover:bg-[#eef6f6] lg:absolute lg:bottom-5 lg:left-5 lg:mt-0">
          Visit YouTube Channel
          <ArrowRight class="h-4 w-4" />
        </a>
      </div>
    </div>
  </section>

  <section class="bg-acc-mist px-5 pt-12 pb-24 sm:px-6 lg:px-8">
    <ResourceTabs active="videos" />
    <div class="mx-auto max-w-6xl">
      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {supportingVideos.map((video) => (
          <article class="reveal-body overflow-hidden rounded-2xl border border-[#d5ded9] bg-white shadow-sm transition hover:-translate-y-0.5 hover:border-[#9fcbd0] hover:shadow-xl hover:shadow-slate-950/7">
            <iframe
              class="aspect-video w-full"
              src={`https://www.youtube-nocookie.com/embed/${video.id}`}
              title={video.title}
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
            ></iframe>
            <div class="p-6">
              <p class="text-[0.68rem] font-black uppercase tracking-[0.24em] text-[#62aebe]">{video.category}</p>
              <h3 class="mt-4 text-xl font-black leading-tight text-acc-ink">{video.title}</h3>
              <p class="mt-4 text-sm font-black uppercase tracking-[0.18em] text-[#164f59]/50">{video.date}</p>
            </div>
          </article>
        ))}
      </div>

      <a href={channelUrl} target="_blank" rel="noreferrer" class="max-w-5xl mx-auto group mt-16 block rounded-3xl bg-[linear-gradient(135deg,#6ec1d5_0%,#5372a7_100%)] p-8 text-white shadow-2xl shadow-[#06333a]/18 transition hover:-translate-y-0.5 sm:p-10 lg:flex lg:items-center lg:justify-between lg:gap-10">
        <div>
          <h2 class="max-w-2xl text-4xl font-black leading-tight">See more videos from the channel.</h2>
        </div>
        <span class="mt-8 inline-flex min-h-12 items-center justify-center gap-2 rounded-full bg-white px-7 text-sm font-black text-[#0b4850] transition group-hover:bg-[#eef6f6] lg:mt-0">
          Open YouTube
          <ArrowRight class="h-4 w-4" />
        </span>
      </a>
    </div>
  </section>
</SiteLayout>
